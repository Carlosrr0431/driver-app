# Copiar a .env y completar valores reales.
# En producción (EAS Build), configurar los mismos nombres como secrets.

# Supabase (obligatorio)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# ── Geoespacial (OSRM + Nominatim en Railway) ────────────────────────────
# Servidor OSRM auto-hospedado — rutas y navegación turn-by-turn
EXPO_PUBLIC_OSRM_URL=https://profesional-osrm-production.up.railway.app

# Servidor Nominatim auto-hospedado — geocodificación y búsqueda (datos OSM)
EXPO_PUBLIC_NOMINATIM_URL=https://profesional-nominatim-production.up.railway.app

# Dashboard (APIs de viaje, fallback geocodificación, agente IA)
EXPO_PUBLIC_DASHBOARD_URL=https://profesional-dashboard.vercel.app

# Opcional: estilo MapLibre vectorial completo (p. ej. https://tiles.openfreemap.org/styles/liberty)
# Por defecto: Carto raster + flechas de sentido único OSM.
# EXPO_PUBLIC_MAP_STYLE_URL=

# Opcional: voz destino (OpenAI)
# EXPO_PUBLIC_OPENAI_API_KEY=

# Desarrollo: login automático al abrir (por defecto desactivado; usar true solo si lo necesitás)
# EXPO_PUBLIC_DEV_AUTO_LOGIN=true
# EXPO_PUBLIC_DEV_DRIVER_EMAIL=
# EXPO_PUBLIC_DEV_DRIVER_PASSWORD=
