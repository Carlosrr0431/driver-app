# Copiar a .env y completar valores reales.
# En producción (EAS Build), configurar los mismos nombres como secrets.

# Supabase (obligatorio)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Mapa OSM (OpenFreeMap — sin API key)
EXPO_PUBLIC_MAP_STYLE_URL=https://tiles.openfreemap.org/styles/liberty

# Desarrollo: APIs públicas (límites estrictos)
# EXPO_PUBLIC_OSRM_URL=https://router.project-osrm.org
# EXPO_PUBLIC_NOMINATIM_URL=https://nominatim.openstreetmap.org

# Producción Railway
EXPO_PUBLIC_OSRM_URL=https://profesional-osrm-production.up.railway.app
EXPO_PUBLIC_NOMINATIM_URL=https://profesional-nominatim-production.up.railway.app
EXPO_PUBLIC_NOMINATIM_USER_AGENT=ProfesionalConductorDriverApp/1.0
EXPO_PUBLIC_NOMINATIM_SELF_HOSTED=true

# Dashboard (transiciones de viaje, pagos)
EXPO_PUBLIC_DASHBOARD_URL=https://profesional-dashboard.vercel.app

# Opcional: voz destino (OpenAI)
# EXPO_PUBLIC_OPENAI_API_KEY=
